{
  "name": "personal-kanban",
  "private": true,
  "workspaces": [
    "packages/client",
    "packages/server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w packages/server\" \"npm run dev -w packages/client\"",
    "build": "npm run build -w packages/client",
    "lint": "npm run lint -w packages/client",
    "test:server": "npm run test -w packages/server",
    "test:e2e": "npx playwright test --config packages/client/playwright.config.ts",
    "test": "npm run test:server && npm run test:e2e"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
